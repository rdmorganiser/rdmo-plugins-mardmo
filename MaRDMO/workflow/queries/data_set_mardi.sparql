SELECT
?id
(CONCAT("mardi:", STRAFTER(STR(?id), STR(wd:))) AS ?qid)
?size_value ?size_unit ?size_record ?file_format
?DOI ?URL ?end_time
(COALESCE(?bot_binary, ?bot_text,    "") AS ?binary_or_text)
(COALESCE(?prop_yes,   ?prop_no,     "") AS ?proprietary)
(COALESCE(?pub_raw,    "NoText")        AS ?publish)
(COALESCE(?arc_raw,    "NoText")        AS ?archive)

WHERE {{

    VALUES ?id {{{0}}}

    OPTIONAL {{
        ?id p:{data size} ?statementNode.
        ?statementNode psv:{data size} ?valueNode.
        ?valueNode wikibase:quantityAmount ?size_value;
                   wikibase:quantityUnit ?unit.
        ?unit rdfs:label ?size_unit.
        FILTER (lang(?size_unit) = 'en')
    }}

    OPTIONAL {{
        ?id wdt:{number of records} ?size_record
    }}

    OPTIONAL {{
        ?id wdt:{file extension} ?file_format
    }}

    OPTIONAL {{ ?id wdt:{instance of} wd:{binary data}.             BIND("binary" AS ?bot_binary) }}
    OPTIONAL {{ ?id wdt:{instance of} wd:{text data}.               BIND("text"   AS ?bot_text)   }}

    OPTIONAL {{ ?id wdt:{instance of} wd:{proprietary information}. BIND("Yes"    AS ?prop_yes)   }}
    OPTIONAL {{ ?id wdt:{instance of} wd:{open data}.               BIND("No"     AS ?prop_no)    }}

    OPTIONAL {{
        ?id wdt:{DOI} ?DOI.
    }}

    OPTIONAL {{
        ?id wdt:{URL} ?URL.
    }}

    OPTIONAL {{ ?id wdt:{mandates} wd:{data publishing}.          BIND("YesText" AS ?pub_raw) }}
    OPTIONAL {{ ?id wdt:{mandates} wd:{research data archiving}.  BIND("YesText" AS ?arc_raw) }}

    OPTIONAL {{
        ?id p:{mandates} ?statementNode2.
        ?statementNode2 ps:{mandates} wd:{research data archiving}.
        OPTIONAL {{
            ?statementNode2 pq:{end time} ?end_time.
        }}
    }}
}}

GROUP BY ?id ?size_value ?size_unit ?size_record ?file_format ?DOI ?URL ?end_time
         ?bot_binary ?bot_text ?prop_yes ?prop_no ?pub_raw ?arc_raw